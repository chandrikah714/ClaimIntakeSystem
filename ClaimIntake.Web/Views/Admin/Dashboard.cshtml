@* ============================================================
   FILE: ClaimIntake.Web/Views/Admin/Dashboard.cshtml
   Redesigned — Clean KPI cards + Chart.js trend charts
   ============================================================ *@

@model ClaimIntake.Web.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    // Use extended model if available (MonthlyTrend)
    var ext = Model as ClaimIntake.Web.Models.AdminDashboardViewModelV2;
}

<div style="max-width:1360px;margin:0 auto;">

    <!-- Page Header -->
    <div class="page-header">
        <div>
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">System overview — <span id="todayDate"></span></p>
        </div>
        <div class="page-actions">
            <a href="/Admin/AllClaims?statusFilter=Pending" class="btn btn-primary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px;"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                Review Pending
            </a>
            <a href="/Admin/RegisterUser" class="btn btn-secondary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px;"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                Add User
            </a>
        </div>
    </div>

    <!-- KPI Grid -->
    <div class="kpi-grid">
        <!-- Total Claims -->
        <div class="kpi-card blue">
            <div class="kpi-header">
                <span class="kpi-label">Total Claims</span>
                <div class="kpi-icon-wrap blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                </div>
            </div>
            <div class="kpi-value">@Model.TotalClaims.ToString("N0")</div>
            <div class="kpi-sub">All time submissions</div>
            <a href="/Admin/AllClaims" class="kpi-link">
                View all
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="9 18 15 12 9 6" /></svg>
            </a>
        </div>

        <!-- Pending -->
        <div class="kpi-card amber">
            <div class="kpi-header">
                <span class="kpi-label">Pending Review</span>
                <div class="kpi-icon-wrap amber">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                </div>
            </div>
            <div class="kpi-value" style="color:var(--warning-solid);">@Model.PendingClaims</div>
            <div class="kpi-sub">Awaiting decision</div>
            <a href="/Admin/AllClaims?statusFilter=Pending" class="kpi-link">
                Review now
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="9 18 15 12 9 6" /></svg>
            </a>
        </div>

        <!-- Approved -->
        <div class="kpi-card green">
            <div class="kpi-header">
                <span class="kpi-label">Approved</span>
                <div class="kpi-icon-wrap green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                </div>
            </div>
            <div class="kpi-value" style="color:var(--success-solid);">@Model.ApprovedClaims</div>
            <div class="kpi-sub">@Model.ApprovalRate.ToString("F1")% approval rate</div>
            <a href="/Admin/AllClaims?statusFilter=Approved" class="kpi-link">
                View approved
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="9 18 15 12 9 6" /></svg>
            </a>
        </div>

        <!-- Rejected -->
        <div class="kpi-card red">
            <div class="kpi-header">
                <span class="kpi-label">Rejected</span>
                <div class="kpi-icon-wrap red">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                </div>
            </div>
            <div class="kpi-value" style="color:var(--error-solid);">@Model.RejectedClaims</div>
            <div class="kpi-sub">@((100 - Model.ApprovalRate).ToString("F1"))% rejection rate</div>
            <a href="/Admin/AllClaims?statusFilter=Rejected" class="kpi-link">
                View rejected
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="9 18 15 12 9 6" /></svg>
            </a>
        </div>

        <!-- Total Amount -->
        <div class="kpi-card purple">
            <div class="kpi-header">
                <span class="kpi-label">Total Value</span>
                <div class="kpi-icon-wrap purple">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                </div>
            </div>
            <div class="kpi-value" style="font-size:22px;">@Model.TotalAmount.ToString("C0")</div>
            <div class="kpi-sub">Avg @Model.AverageClaimAmount.ToString("C0") per claim</div>
        </div>

        <!-- Active Users -->
        <div class="kpi-card blue">
            <div class="kpi-header">
                <span class="kpi-label">Active Users</span>
                <div class="kpi-icon-wrap blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75" /></svg>
                </div>
            </div>
            <div class="kpi-value">@Model.ActiveUsers</div>
            <div class="kpi-sub">System members</div>
            <a href="/Admin/UserManagement" class="kpi-link">
                Manage
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="9 18 15 12 9 6" /></svg>
            </a>
        </div>
    </div>

    <!-- Charts Row -->
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:24px;">

        <!-- Trend Line Chart -->
        <div class="card card-padded">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
                <div>
                    <div class="card-title">Claims Trend</div>
                    <div style="font-size:12px;color:var(--surface-400);margin-top:2px;">Last 6 months</div>
                </div>
                <div style="display:flex;gap:16px;font-size:12px;">
                    <span style="display:flex;align-items:center;gap:5px;color:var(--surface-500);">
                        <span style="width:10px;height:10px;border-radius:2px;background:#3b82f6;display:inline-block;"></span>Total
                    </span>
                    <span style="display:flex;align-items:center;gap:5px;color:var(--surface-500);">
                        <span style="width:10px;height:10px;border-radius:2px;background:#16a34a;display:inline-block;"></span>Approved
                    </span>
                    <span style="display:flex;align-items:center;gap:5px;color:var(--surface-500);">
                        <span style="width:10px;height:10px;border-radius:2px;background:#dc2626;display:inline-block;"></span>Rejected
                    </span>
                </div>
            </div>
            <div style="position:relative;height:240px;">
                <canvas id="trendChart" role="img" aria-label="Monthly claims trend over last 6 months"></canvas>
            </div>
        </div>

        <!-- Status Donut -->
        <div class="card card-padded">
            <div class="card-title" style="margin-bottom:8px;">Status Breakdown</div>
            <div style="font-size:12px;color:var(--surface-400);margin-bottom:20px;">Current distribution</div>
            <div style="position:relative;height:180px;">
                <canvas id="donutChart" role="img" aria-label="Claims status breakdown donut chart"></canvas>
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;margin-top:16px;">
                <div style="display:flex;justify-content:space-between;align-items:center;font-size:13px;">
                    <span style="display:flex;align-items:center;gap:8px;color:var(--surface-600);">
                        <span style="width:10px;height:10px;border-radius:50%;background:#d97706;display:inline-block;"></span>Pending
                    </span>
                    <span style="font-weight:600;color:var(--surface-800);">@Model.PendingClaims</span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;font-size:13px;">
                    <span style="display:flex;align-items:center;gap:8px;color:var(--surface-600);">
                        <span style="width:10px;height:10px;border-radius:50%;background:#16a34a;display:inline-block;"></span>Approved
                    </span>
                    <span style="font-weight:600;color:var(--surface-800);">@Model.ApprovedClaims</span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;font-size:13px;">
                    <span style="display:flex;align-items:center;gap:8px;color:var(--surface-600);">
                        <span style="width:10px;height:10px;border-radius:50%;background:#dc2626;display:inline-block;"></span>Rejected
                    </span>
                    <span style="font-weight:600;color:var(--surface-800);">@Model.RejectedClaims</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Row: Quick Actions + System Health -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;margin-bottom:24px;">

        <!-- Quick Actions -->
        <a href="/Admin/AllClaims?statusFilter=Pending" style="text-decoration:none;">
            <div class="card card-padded" style="transition:all 200ms;cursor:pointer;"
                 onmouseover="this.style.borderColor='var(--brand-400)'"
                 onmouseout="this.style.borderColor='var(--surface-200)'">
                <div style="width:44px;height:44px;background:var(--warning-bg);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                    <svg style="width:22px;height:22px;color:var(--warning-solid);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                </div>
                <div style="font-size:15px;font-weight:700;color:var(--surface-900);margin-bottom:4px;">Review Claims</div>
                <div style="font-size:13px;color:var(--surface-500);">@Model.PendingClaims pending review</div>
            </div>
        </a>

        <a href="/Admin/RegisterUser" style="text-decoration:none;">
            <div class="card card-padded" style="transition:all 200ms;cursor:pointer;"
                 onmouseover="this.style.borderColor='var(--brand-400)'"
                 onmouseout="this.style.borderColor='var(--surface-200)'">
                <div style="width:44px;height:44px;background:var(--brand-50);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                    <svg style="width:22px;height:22px;color:var(--brand-600);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="8.5" cy="7" r="4" /><line x1="20" y1="8" x2="20" y2="14" /><line x1="23" y1="11" x2="17" y2="11" /></svg>
                </div>
                <div style="font-size:15px;font-weight:700;color:var(--surface-900);margin-bottom:4px;">Register User</div>
                <div style="font-size:13px;color:var(--surface-500);">Add new system user</div>
            </div>
        </a>

        <a href="/Admin/UserManagement" style="text-decoration:none;">
            <div class="card card-padded" style="transition:all 200ms;cursor:pointer;"
                 onmouseover="this.style.borderColor='var(--brand-400)'"
                 onmouseout="this.style.borderColor='var(--surface-200)'">
                <div style="width:44px;height:44px;background:var(--success-bg);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                    <svg style="width:22px;height:22px;color:var(--success-solid);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75" /></svg>
                </div>
                <div style="font-size:15px;font-weight:700;color:var(--surface-900);margin-bottom:4px;">Manage Users</div>
                <div style="font-size:13px;color:var(--surface-500);">@Model.ActiveUsers active accounts</div>
            </div>
        </a>
    </div>

    <!-- System Status -->
    <div class="card" style="padding:20px 24px;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
            <div style="font-size:14px;font-weight:700;color:var(--surface-700);">System Status</div>
            <div style="display:flex;gap:24px;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:8px;">
                    <div style="width:8px;height:8px;border-radius:50%;background:var(--success-solid);"></div>
                    <span style="font-size:13px;color:var(--surface-600);">Database</span>
                    <span style="font-size:12px;color:var(--success-text);background:var(--success-bg);padding:2px 8px;border-radius:var(--r-full);">Operational</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <div style="width:8px;height:8px;border-radius:50%;background:var(--success-solid);"></div>
                    <span style="font-size:13px;color:var(--surface-600);">API</span>
                    <span style="font-size:12px;color:var(--success-text);background:var(--success-bg);padding:2px 8px;border-radius:var(--r-full);">Operational</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <div style="width:8px;height:8px;border-radius:50%;background:var(--success-solid);"></div>
                    <span style="font-size:13px;color:var(--surface-600);">Queue</span>
                    <span style="font-size:12px;color:var(--success-text);background:var(--success-bg);padding:2px 8px;border-radius:var(--r-full);">Operational</span>
                </div>
                <div style="font-size:12px;color:var(--surface-400);display:flex;align-items:center;">
                    Last checked: <span id="lastChecked" style="margin-left:4px;font-family:var(--font-mono);"></span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script>
        document.getElementById('todayDate').textContent =
        new Date().toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
        document.getElementById('lastChecked').textContent =
        new Date().toLocaleTimeString('en-US', { hour:'2-digit', minute:'2-digit' });

        // Trend Chart (line)
        @{
            // Fallback data if no monthly trend model
            var labels = ext?.MonthLabels ?? "['6M ago','5M ago','4M ago','3M ago','2M ago','This month']";
            var totals = ext?.MonthTotals ?? "[0,0,0,0,0,@Model.TotalClaims]";
            var approved = ext?.MonthApproved ?? "[0,0,0,0,0,@Model.ApprovedClaims]";
            var rejected = ext?.MonthRejected ?? "[0,0,0,0,0,@Model.RejectedClaims]";
        }

        const trendCtx = document.getElementById('trendChart');
        new Chart(trendCtx, {
        type: 'line',
        data: {
        labels: @Html.Raw(labels),
        datasets: [
        {
        label: 'Total',
        data: @Html.Raw(totals),
        borderColor: '#3b82f6',
        backgroundColor: 'rgba(59,130,246,0.08)',
        fill: true,
        tension: 0.4,
        pointRadius: 4,
        pointBackgroundColor: '#3b82f6',
        borderWidth: 2
        },
        {
        label: 'Approved',
        data: @Html.Raw(approved),
        borderColor: '#16a34a',
        backgroundColor: 'transparent',
        fill: false,
        tension: 0.4,
        pointRadius: 4,
        pointBackgroundColor: '#16a34a',
        borderWidth: 2,
        borderDash: []
        },
        {
        label: 'Rejected',
        data: @Html.Raw(rejected),
        borderColor: '#dc2626',
        backgroundColor: 'transparent',
        fill: false,
        tension: 0.4,
        pointRadius: 4,
        pointBackgroundColor: '#dc2626',
        borderWidth: 2,
        borderDash: [4, 3]
        }
        ]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
        legend: { display: false },
        tooltip: {
        backgroundColor: '#1e293b',
        titleColor: '#f8fafc',
        bodyColor: '#94a3b8',
        padding: 12,
        cornerRadius: 8,
        callbacks: {
        label: ctx => ` ${ctx.dataset.label}: ${Math.round(ctx.parsed.y)}`
        }
        }
        },
        scales: {
        x: {
        grid: { display: false },
        ticks: { color: '#94a3b8', font: { size: 12 } }
        },
        y: {
        beginAtZero: true,
        grid: { color: 'rgba(0,0,0,0.05)' },
        ticks: {
        color: '#94a3b8',
        font: { size: 12 },
        stepSize: 1,
        precision: 0
        }
        }
        }
        }
        });

        // Donut Chart
        const donutCtx = document.getElementById('donutChart');
        new Chart(donutCtx, {
        type: 'doughnut',
        data: {
        labels: ['Pending', 'Approved', 'Rejected'],
        datasets: [{
        data: [@Model.PendingClaims, @Model.ApprovedClaims, @Model.RejectedClaims],
        backgroundColor: ['#d97706', '#16a34a', '#dc2626'],
        borderColor: '#ffffff',
        borderWidth: 3,
        hoverBorderWidth: 3
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '72%',
        plugins: {
        legend: { display: false },
        tooltip: {
        backgroundColor: '#1e293b',
        titleColor: '#f8fafc',
        bodyColor: '#94a3b8',
        padding: 10,
        cornerRadius: 8
        }
        }
        }
        });
    </script>
}
