@* ============================================================
   FILE: ClaimIntake.Web/Views/Shared/_Layout.cshtml
   Redesigned — DM Sans font, notification bell, clean navbar
   ============================================================ *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Claims Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- ── NAVBAR ──────────────────────────────────────── -->
        <nav class="navbar">
            <div class="navbar-inner">
                <!-- Brand -->
                <a href="/" class="nav-brand" style="text-decoration:none">
                    <div class="nav-brand-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <span class="nav-brand-text">Claims<span>Portal</span></span>
                </a>

                <!-- Nav Links -->
                <div class="nav-links">
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Dashboard" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                            Dashboard
                        </a>
                        <a href="/Admin/AllClaims" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "AllClaims" ? "active" : "")">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                            All Claims
                        </a>
                        <a href="/Admin/UserManagement" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "UserManagement" ? "active" : "")">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75" /></svg>
                            Users
                        </a>
                        <a href="/Admin/RegisterUser" class="nav-link">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="8.5" cy="7" r="4" /><line x1="20" y1="8" x2="20" y2="14" /><line x1="23" y1="11" x2="17" y2="11" /></svg>
                            Register
                        </a>
                    }
                    else
                    {
                        <a href="/MyAccount/MyClaims" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "MyClaims" ? "active" : "")">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                            My Claims
                        </a>
                        <a href="/Claim/Submit" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Submit" ? "active" : "")">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                            Submit Claim
                        </a>
                        <a href="/MyAccount/Profile" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                            Profile
                        </a>
                    }
                </div>

                <!-- Right section: Bell + User -->
                <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">

                    <!-- Notification Bell -->
                    <div style="position:relative;">
                        <button class="nav-bell" id="bellBtn" onclick="toggleNotifications()" aria-label="Notifications">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0" />
                            </svg>
                            @{
                                var unread = ViewBag.UnreadNotificationCount as int? ?? 0;
                            }
                            @if (unread > 0)
                            {
                                <span class="bell-badge" id="bellBadge">@(unread > 9 ? "9+" : unread.ToString())</span>
                            }
                        </button>

                        <!-- Notification Dropdown -->
                        <div class="notification-dropdown" id="notifDropdown">
                            <div class="notif-header">
                                <h4>Notifications</h4>
                                <button class="notif-mark-all" onclick="markAllRead()">Mark all read</button>
                            </div>
                            <div class="notif-list" id="notifList">
                                <div class="notif-empty">Loading notifications...</div>
                            </div>
                            <div class="notif-footer">
                                <a href="/Notifications">View all notifications</a>
                            </div>
                        </div>
                    </div>

                    <!-- User Menu -->
                    <div style="position:relative;">
                        <button class="nav-user" id="userMenuBtn" onclick="toggleUserMenu()">
                            <div class="user-avatar">@(User.Identity?.Name?.Substring(0, 1).ToUpper())</div>
                            <span class="user-name">@User.Identity?.Name</span>
                            @if (User.IsInRole("Admin"))
                            {
                                <span class="user-role-pill admin">Admin</span>
                            }
                            else
                            {
                                <span class="user-role-pill user">User</span>
                            }
                            <svg style="width:12px;height:12px;color:var(--surface-400);transition:transform 200ms;" id="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <polyline points="6 9 12 15 18 9" />
                            </svg>
                        </button>

                        <div class="user-dropdown" id="userDropdown">
                            @if (!User.IsInRole("Admin"))
                            {
                                <a href="/MyAccount/Profile" class="dropdown-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" /></svg>
                                    My Profile
                                </a>
                                <a href="/MyAccount/MyClaims" class="dropdown-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                    My Claims
                                </a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a href="/Admin/Dashboard" class="dropdown-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                                    Dashboard
                                </a>
                            }
                            <div class="dropdown-sep"></div>
                            <a href="/Account/Logout" class="dropdown-item danger">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                                Sign Out
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    }

    <!-- ── MAIN CONTENT ────────────────────────────────────── -->
    <main class="@(User.Identity?.IsAuthenticated == true ? "main-content" : "")">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success" style="margin-bottom:var(--sp-5);max-width:1360px;margin-left:auto;margin-right:auto;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error" style="margin-bottom:var(--sp-5);max-width:1360px;margin-left:auto;margin-right:auto;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                @TempData["ErrorMessage"]
            </div>
        }
        @RenderBody()
    </main>

    <!-- ── TOAST CONTAINER ─────────────────────────────────── -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- ── FOOTER ─────────────────────────────────────────── -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        <footer class="site-footer">
            <div class="footer-inner">
                <div class="footer-brand">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
                        <div style="width:32px;height:32px;background:linear-gradient(135deg,var(--brand-600),var(--brand-800));border-radius:8px;display:flex;align-items:center;justify-content:center;">
                            <svg style="width:16px;height:16px;color:white;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                        </div>
                        <span style="font-size:15px;font-weight:700;color:white;">ClaimsPortal</span>
                    </div>
                    <p>Secure, encrypted medical claim management system with real-time processing and role-based access control.</p>
                </div>
                <div class="footer-col">
                    <h5>Quick Links</h5>
                    <ul>
                        @if (User.IsInRole("Admin"))
                        {
                            <li><a href="/Admin/Dashboard">Dashboard</a></li>
                            <li><a href="/Admin/AllClaims">All Claims</a></li>
                            <li><a href="/Admin/UserManagement">User Management</a></li>
                        }
                        else
                        {
                            <li><a href="/MyAccount/MyClaims">My Claims</a></li>
                            <li><a href="/Claim/Submit">Submit Claim</a></li>
                            <li><a href="/MyAccount/Profile">My Profile</a></li>
                        }
                    </ul>
                </div>
                <div class="footer-col">
                    <h5>Security</h5>
                    <ul>
                        <li><a href="#">AES-256 Encrypted</a></li>
                        <li><a href="#">HIPAA Compliant</a></li>
                        <li><a href="#">Audit Logging</a></li>
                        <li><a href="#">Role-Based Access</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <span>&copy; 2025 ClaimsPortal. All rights reserved.</span>
                <span style="font-family:var(--font-mono);font-size:11px;color:var(--surface-600);">v2.0.0 · AES-256</span>
            </div>
        </footer>
    }

    @await RenderSectionAsync("Scripts", required: false)

    <script>
            // ── Dropdown Toggles ──────────────────────────────────────
            function toggleNotifications() {
                const d = document.getElementById('notifDropdown');
                const isOpen = d.classList.contains('open');
                closeAll();
                if (!isOpen) {
                    d.classList.add('open');
                    loadNotifications();
                }
            }

            function toggleUserMenu() {
                const d = document.getElementById('userDropdown');
                const chevron = document.getElementById('chevron');
                const isOpen = d.classList.contains('open');
                closeAll();
                if (!isOpen) {
                    d.classList.add('open');
                    if (chevron) chevron.style.transform = 'rotate(180deg)';
                }
            }

            function closeAll() {
                document.querySelectorAll('.notification-dropdown, .user-dropdown').forEach(el => el.classList.remove('open'));
                const c = document.getElementById('chevron');
                if (c) c.style.transform = '';
            }

            document.addEventListener('click', function(e) {
                const bellBtn  = document.getElementById('bellBtn');
                const userBtn  = document.getElementById('userMenuBtn');
                const notifD   = document.getElementById('notifDropdown');
                const userD    = document.getElementById('userDropdown');
                if (!bellBtn?.contains(e.target) && !notifD?.contains(e.target) &&
                    !userBtn?.contains(e.target) && !userD?.contains(e.target)) {
                    closeAll();
                }
            });

            // ── Notification Loader ───────────────────────────────────
            async function loadNotifications() {
                const list = document.getElementById('notifList');
                if (!list) return;
                try {
                    const res  = await fetch('/Notifications/Recent');
                    const data = await res.json();
                    if (!data.length) {
                        list.innerHTML = '<div class="notif-empty">You\'re all caught up! 🎉</div>';
                        return;
                    }
                    list.innerHTML = data.map(n => `
                        <a href="${n.actionUrl || '#'}" class="notif-item ${n.isRead ? '' : 'unread'}"
                           onclick="markRead(${n.notificationId}, event)">
                            <div class="notif-icon ${n.type.toLowerCase()}">${iconFor(n.type)}</div>
                            <div class="notif-content">
                                <div class="notif-title">${escHtml(n.title)}</div>
                                <div class="notif-msg">${escHtml(n.message)}</div>
                                <div class="notif-time">${timeAgo(n.createdAt)}</div>
                            </div>
                            <div class="notif-dot ${n.isRead ? 'read' : 'unread'}"></div>
                        </a>`).join('');
                } catch {
                    list.innerHTML = '<div class="notif-empty">Could not load notifications.</div>';
                }
            }

            function iconFor(type) {
                const icons = {
                    Success: '✓', Error: '✕', Warning: '!', Claim: '📋', Info: 'ℹ'
                };
                return icons[type] || 'ℹ';
            }

            async function markRead(id, e) {
                try {
                    await fetch('/Notifications/MarkRead/' + id, { method: 'POST' });
                    updateBadge(-1);
                } catch {}
            }

            async function markAllRead() {
                try {
                    await fetch('/Notifications/MarkAllRead', { method: 'POST' });
                    const badge = document.getElementById('bellBadge');
                    if (badge) badge.remove();
                    loadNotifications();
                } catch {}
            }

            function updateBadge(delta) {
                const badge = document.getElementById('bellBadge');
                if (!badge) return;
                let count = parseInt(badge.textContent) + delta;
                if (count <= 0) badge.remove();
                else badge.textContent = count > 9 ? '9+' : count;
            }

            function timeAgo(dateStr) {
                const diff = (Date.now() - new Date(dateStr)) / 1000;
                if (diff < 60)    return 'just now';
                if (diff < 3600)  return Math.floor(diff/60)  + 'm ago';
                if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
                return Math.floor(diff/86400) + 'd ago';
            }

            function escHtml(s) {
                return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            }

            // ── Toast System ──────────────────────────────────────────
            window.showToast = function(title, msg, type = 'info') {
                const c = document.getElementById('toastContainer');
                if (!c) return;
                const icons = {
                    success: '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
                    error:   '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>',
                    warning: '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
                    info:    '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>'
                };
                const t = document.createElement('div');
                t.className = `toast ${type}`;
                t.innerHTML = `${icons[type] || icons.info}
                    <div><div class="toast-title">${escHtml(title)}</div><div class="toast-msg">${escHtml(msg)}</div></div>
                    <button class="toast-close" onclick="this.parentElement.remove()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>`;
                c.appendChild(t);
                setTimeout(() => t.remove(), 5000);
            };
    </script>
</body>
</html>
