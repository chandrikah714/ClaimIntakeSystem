@* ============================================================
   FILE: ClaimIntake.Web/Views/Account/ChangePassword.cshtml
   FIXES: @@media, no arrow fns, no JS template literals
   ============================================================ *@

@model ClaimIntake.Web.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<style>
.cp-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 24px;
    max-width: 860px;
    margin: 0 auto;
}

@@media (max-width: 700px) {
    .cp-grid { grid-template-columns: 1fr; }
}

.strength-bar-wrap {
    height: 5px;
    background: var(--surface-100);
    border-radius: var(--r-full);
    overflow: hidden;
    margin-top: 8px;
}

.strength-bar {
    height: 100%;
    border-radius: var(--r-full);
    transition: width 300ms ease, background 300ms ease;
    width: 0%;
}

.pwd-rules { display: flex; flex-direction: column; gap: 6px; margin-top: 10px; }

.pwd-rule {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--surface-400);
    transition: color 200ms;
}

.pwd-rule.ok   { color: var(--success-solid); }
.pwd-rule.fail { color: var(--error-solid); }

.rule-icon {
    width: 16px; height: 16px;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    font-size: 10px; font-weight: 700;
    transition: all 200ms;
}

.pwd-rule.ok .rule-icon {
    background: var(--success-solid);
    border-color: var(--success-solid);
    color: white;
}

.sec-tip {
    display: flex;
    gap: 12px;
    padding: 12px;
    background: var(--surface-50);
    border-radius: var(--r-md);
    border: 1px solid var(--surface-200);
    font-size: 12px;
    color: var(--surface-600);
    margin-bottom: 10px;
}

.sec-tip svg { width: 16px; height: 16px; flex-shrink: 0; color: var(--brand-500); margin-top: 1px; }

.pwr-btn-abs {
    position: absolute;
    right: 12px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none;
    color: var(--surface-400);
    cursor: pointer; padding: 4px;
    display: flex;
}
</style>

<div class="cp-grid">

    <!-- Form -->
    <div>
        <div class="page-header" style="margin-bottom:20px;">
            <div>
                <h1 class="page-title">Change Password</h1>
                <p class="page-subtitle">Update your account security credentials</p>
            </div>
            <a href="/MyAccount/Profile" class="btn btn-secondary">&#8592; Back to Profile</a>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-error" style="margin-bottom:20px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                @Model.ErrorMessage
            </div>
        }

        <form asp-action="ChangePassword" asp-controller="Account" method="post" id="cpForm">
            @Html.AntiForgeryToken()

            <div class="card card-padded">

                <!-- Current Password -->
                <div class="form-group" style="margin-bottom:20px;">
                    <label asp-for="CurrentPassword" class="form-label">Current Password <span style="color:var(--error-solid)">*</span></label>
                    <div style="position:relative;">
                        <input asp-for="CurrentPassword" type="password" id="currentPwd"
                               class="form-control" placeholder="Your current password"
                               style="padding-right:44px;"
                               autocomplete="current-password" />
                        <button type="button" class="pwr-btn-abs" onclick="togglePwd('currentPwd','eye0')">
                            <svg id="eye0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="CurrentPassword" class="form-error"></span>
                </div>

                <div style="height:1px;background:var(--surface-100);margin-bottom:20px;"></div>

                <!-- New Password -->
                <div class="form-group" style="margin-bottom:16px;">
                    <label asp-for="NewPassword" class="form-label">New Password <span style="color:var(--error-solid)">*</span></label>
                    <div style="position:relative;">
                        <input asp-for="NewPassword" type="password" id="newPwd"
                               class="form-control" placeholder="Choose a strong new password"
                               style="padding-right:44px;"
                               oninput="onPwdInput(this)"
                               autocomplete="new-password" />
                        <button type="button" class="pwr-btn-abs" onclick="togglePwd('newPwd','eye1')">
                            <svg id="eye1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>

                    <div class="strength-bar-wrap"><div class="strength-bar" id="sBar"></div></div>
                    <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--surface-400);margin-top:4px;">
                        <span id="sLabel" style="font-weight:600;"></span>
                        <span>Strength</span>
                    </div>

                    <div class="pwd-rules">
                        <div class="pwd-rule" id="r-len"><div class="rule-icon">&#10003;</div> At least 8 characters</div>
                        <div class="pwd-rule" id="r-upper"><div class="rule-icon">&#10003;</div> One uppercase letter</div>
                        <div class="pwd-rule" id="r-lower"><div class="rule-icon">&#10003;</div> One lowercase letter</div>
                        <div class="pwd-rule" id="r-num"><div class="rule-icon">&#10003;</div> One number</div>
                        <div class="pwd-rule" id="r-special"><div class="rule-icon">&#10003;</div> One special character</div>
                    </div>
                    <span asp-validation-for="NewPassword" class="form-error"></span>
                </div>

                <!-- Confirm -->
                <div class="form-group" style="margin-bottom:24px;">
                    <label asp-for="ConfirmNewPassword" class="form-label">Confirm New Password <span style="color:var(--error-solid)">*</span></label>
                    <div style="position:relative;">
                        <input asp-for="ConfirmNewPassword" type="password" id="confPwd"
                               class="form-control" placeholder="Repeat your new password"
                               style="padding-right:44px;"
                               oninput="onConfirmInput(this)"
                               autocomplete="new-password" />
                        <button type="button" class="pwr-btn-abs" onclick="togglePwd('confPwd','eye2')">
                            <svg id="eye2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <div id="confirmFb" style="font-size:12px;margin-top:5px;min-height:16px;"></div>
                    <span asp-validation-for="ConfirmNewPassword" class="form-error"></span>
                </div>

                <div style="display:flex;gap:12px;">
                    <button type="submit" class="btn btn-primary" id="cpBtn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                        <span id="cpBtnLabel">Update Password</span>
                    </button>
                    <a href="/MyAccount/Profile" class="btn btn-ghost">Cancel</a>
                </div>
            </div>
        </form>
    </div>

    <!-- Sidebar -->
    <div>
        <div class="card card-padded">
            <div style="font-size:13px;font-weight:700;color:var(--surface-700);margin-bottom:16px;">Security Tips</div>
            <div class="sec-tip">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Use a unique password not used on other websites
            </div>
            <div class="sec-tip">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Mix letters, numbers, and special characters
            </div>
            <div class="sec-tip">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Avoid personal info like names or birthdays
            </div>
            <div class="sec-tip">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Passwords are hashed with BCrypt — never visible
            </div>

            <div style="margin-top:20px;padding:14px;background:var(--warning-bg);border:1px solid var(--warning-border);border-radius:var(--r-lg);">
                <div style="font-size:12px;font-weight:700;color:var(--warning-text);margin-bottom:6px;">After changing</div>
                <div style="font-size:12px;color:var(--warning-text);line-height:1.5;">You will stay logged in. Other active sessions will be invalidated.</div>
            </div>
        </div>
    </div>
</div>

<script>
var cpRules = [
    { re: /.{8,}/,          id: 'r-len'     },
    { re: /[A-Z]/,          id: 'r-upper'   },
    { re: /[a-z]/,          id: 'r-lower'   },
    { re: /[0-9]/,          id: 'r-num'     },
    { re: /[$!%*?&\-_#^]/, id: 'r-special' }
];

var cpColors = ['','#ef4444','#f97316','#eab308','#22c55e','#16a34a'];
var cpLabels = ['','Very Weak','Weak','Fair','Strong','Very Strong'];

function onPwdInput(el) {
    var v     = el.value;
    var score = 0;
    for (var i = 0; i < cpRules.length; i++) {
        var ok   = cpRules[i].re.test(v);
        var node = document.getElementById(cpRules[i].id);
        if (ok) { score++; node.classList.add('ok'); node.classList.remove('fail'); }
        else    { node.classList.remove('ok'); if (v.length > 0) node.classList.add('fail'); else node.classList.remove('fail'); }
    }
    var bar          = document.getElementById('sBar');
    bar.style.width  = score > 0 ? (score * 20) + '%' : '0%';
    bar.style.background = score > 0 ? cpColors[score] : 'transparent';
    var lbl          = document.getElementById('sLabel');
    lbl.textContent  = score > 0 ? cpLabels[score] : '';
    lbl.style.color  = score > 0 ? cpColors[score] : '';
    var conf         = document.getElementById('confPwd');
    if (conf.value)  { onConfirmInput(conf); }
}

function onConfirmInput(el) {
    var main = document.getElementById('newPwd').value;
    var fb   = document.getElementById('confirmFb');
    if (!el.value) { fb.textContent = ''; return; }
    var match = (el.value === main);
    fb.style.color  = match ? 'var(--success-solid)' : 'var(--error-solid)';
    fb.textContent  = match ? 'Passwords match' : 'Passwords do not match';
}

function togglePwd(inputId, iconId) {
    var input = document.getElementById(inputId);
    var icon  = document.getElementById(iconId);
    if (input.type === 'password') {
        input.type     = 'text';
        icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
    } else {
        input.type     = 'password';
        icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
    }
}

document.getElementById('cpForm').addEventListener('submit', function() {
    document.getElementById('cpBtn').disabled      = true;
    document.getElementById('cpBtnLabel').textContent = 'Updating...';
});
</script>
